# ╔══════════════════════════════════════════════════════════════════════════╗
# ║              DISTRIBUTED SYSTEM CONFIGURATION                            ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║  1. Copy file này thành config.properties                                ║
# ║  2. Sửa IP theo mạng thực tế của nhóm bạn                               ║
# ║  3. Copy file config.properties giống nhau lên TẤT CẢ 4 máy            ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ============== PHÂN BỔ MÁY ==============
# Máy 1 (192.168.1.10)   : Client (Thành viên 1)
# Máy 2 (192.168.1.100)  : Load Balancer (Thành viên 2)
# Máy 3 (192.168.1.101)  : Worker Server 1 (Thành viên 3)
# Máy 4 (192.168.1.102)  : Worker Server 2 + MySQL (Thành viên 4)

# ============== LOAD BALANCER (Máy 2) ==============
LOAD_BALANCER_HOST=192.168.1.100
LOAD_BALANCER_PORT=8080

# ============== WORKER SERVERS ==============
# Worker 1 (Máy 3)
WORKER1_HOST=192.168.1.101
WORKER1_PORT=9001

# Worker 2 (Máy 4) - cùng máy với Database
WORKER2_HOST=192.168.1.102
WORKER2_PORT=9002

# ============== DATABASE (Máy 4) ==============
# MySQL chạy trên cùng máy với Worker 2
DB_URL=jdbc:mysql://192.168.1.102:3306/distributed_db
DB_USER=root
DB_PASSWORD=password

# ============== SSL/TLS (Optional) ==============
# Bật/tắt SSL encryption (true/false)
SSL_ENABLED=false

# Đường dẫn đến keystore file (chứa certificate)
SSL_KEYSTORE_PATH=keystore.jks

# Password của keystore
SSL_KEYSTORE_PASSWORD=changeit

# Password của private key trong keystore
SSL_KEY_PASSWORD=changeit

# ============== TẠO SSL CERTIFICATE ==============
# Chạy lệnh sau để tạo self-signed certificate:
# keytool -genkeypair -alias distributed-system -keyalg RSA -keysize 2048 -validity 365 -keystore keystore.jks -storepass changeit -keypass changeit

# ============== ACCESS CONTROL (TCP Connection ACL) ==============
# Approval mode: AUTO (use whitelist/blacklist) or MANUAL (admin approves each connection)
# ACL_APPROVAL_MODE=AUTO

# Timeout for manual approval in milliseconds (default: 30000 = 30 seconds)
# ACL_MANUAL_TIMEOUT_MS=30000

# Whitelist/Blacklist managed dynamically via Admin Dashboard UI
# and auto-persisted to acl.properties file

# ============== CÁCH CHẠY VỚI ADMIN DASHBOARD ==============
# Thay vì runWorker1/runWorker2, chạy runAdmin1/runAdmin2 để có UI quản trị:
#   .\gradlew.bat :server-node:runAdmin1    (Worker 1 + Admin UI)
#   .\gradlew.bat :server-node:runAdmin2    (Worker 2 + Admin UI)
#   .\gradlew.bat :load-balancer:runAdmin   (Load Balancer + Admin UI)

